{
  "name": "neck-guardian",
  "version": "1.0.0",
  "description": "肩颈健康助手 - NeckGuardian",
  "main": "dist/main.js",
  "author": "NeckGuardian Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/cwxa/HealthyDesk.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder",
    "python:install": "pip install -r backend/requirements.txt",
    "python:start": "python backend/main.py",
    "start": "concurrently \"npm run python:start\" \"npm run electron:dev\"",
    "icons:generate": "node scripts/generate-icons.js",
    "publish": "tsc && vite build && electron-builder --publish always"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "lucide-react": "^1.14.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.3.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
